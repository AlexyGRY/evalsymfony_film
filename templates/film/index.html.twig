{% extends 'base.html.twig' %}

{% block title %}Hello FilmController!{% endblock %}

{% block body %}
    <h1>Liste des films</h1>
    <ul>
        {% for film in films %}
            <div class="card" style="width: 18rem;">
            <img src="{{film.affiche}}" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title">{{ film.titre }}</h5>
                    <p class="card-text">{{ film.description }}</p>
                    <p class="card-text">{{ film.sortie}}</p>
                    
                    <a href="{{ path('app_film_show', {'id': film.id}) }}" class="btn btn-primary">Details du film</a>

                </div>
            </div>
        {% endfor %}
    </ul>
{% endblock %}
